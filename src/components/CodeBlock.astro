---
interface Props {
  code: string;
  lang?: string;
  label?: string;
  copyable?: boolean;
}

const { code, lang = 'bash', label, copyable = true } = Astro.props;
const id = `cb-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="rounded-lg overflow-hidden border border-[var(--color-border)] my-6">
  <div class="flex items-center justify-between px-4 py-2 bg-[var(--color-surface-2)] border-b border-[var(--color-border)]">
    <span class="text-xs font-mono text-[var(--color-muted)]">{label ?? lang}</span>
    {copyable && (
      <button
        data-copy-target={id}
        class="text-xs font-mono text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors cursor-pointer"
        aria-label="Copy code"
      >
        copy
      </button>
    )}
  </div>
  <pre
    id={id}
    class="overflow-x-auto p-4 text-sm leading-relaxed bg-[var(--color-surface)]"
  ><code class={`language-${lang} font-mono text-[var(--color-text)]`}>{code}</code></pre>
</div>

<script>
  document.querySelectorAll('[data-copy-target]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const target = document.getElementById((btn as HTMLElement).dataset.copyTarget!);
      if (!target) return;
      await navigator.clipboard.writeText(target.innerText.trim());
      btn.textContent = 'copied!';
      setTimeout(() => { btn.textContent = 'copy'; }, 2000);
    });
  });
</script>
