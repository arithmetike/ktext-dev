---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ScoreCard from '../components/ScoreCard.astro';
import Footer from '../components/Footer.astro';

const installCmd = 'go install github.com/arithmetike/ktext/cmd/ktext@latest';

const yamlExample = `ktext: "1.0.0"
identity:
  name: my-service
  url: https://github.com/org/my-service
  type: service
  status: active
  purpose: Handles payment processing for the checkout flow.

constraints:
  - content: Never log raw card data or PII in any request handler
    why: PCI compliance
  - content: Always validate input at the service boundary before domain logic
    why: Defense in depth

decisions:
  - title: Use PostgreSQL for all persistent state
    rationale: Need transactional integrity and JSONB support for flexible metadata
    status: accepted
    date: "2024-03"

conventions:
  - rule: Run all DB queries through the repository layer, no raw SQL in handlers
    why: Keeps the domain layer testable and persistence swappable

risks:
  - content: Migration rollback untested beyond 2 schema versions
    severity: high
    mitigation: Add rollback smoke test to CI before next release

dependencies:
  - name: PostgreSQL
    url: https://www.postgresql.org
    why: Primary data store, transactions and JSONB
  - name: Redis
    url: https://redis.io
    why: Session cache and rate-limit counters

working:
  commands:
    - command: make build
      description: build the service binary
    - command: make test
      description: run unit and integration tests
    - command: make migrate
      description: apply pending database migrations
  structure:
    - path: internal/payments/
      description: payment processing logic and provider integrations
    - path: internal/repository/
      description: all database access, no SQL outside this package
  notes:
    - Run migrations before starting the server locally
    - Set STRIPE_WEBHOOK_SECRET in .env.local for webhook testing

ownership:
  team: platform
  escalation: https://github.com/org/my-service/issues`;

const steps = [
  {
    cmd: 'ktext init',
    label: '01 / init',
    title: 'Scan and generate',
    desc: 'Reads your README, Makefile, package manifests, ADRs, and directory layout. Walks you through each discovered field so you can confirm or correct.',
  },
  {
    cmd: 'ktext validate',
    label: '02 / validate',
    title: 'Score quality',
    desc: 'Scores all eight sections out of 100. Reports what is missing and what to fix. Exits 1 below threshold so you can gate on it in CI.',
  },
  {
    cmd: 'ktext export xml',
    label: '03 / export',
    title: 'Export anywhere',
    desc: 'Renders CONTEXT.yaml as compact XML for direct injection into LLM context windows, or as JSON for scripts and pipelines.',
  },
];
---

<Base>
  <Nav />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-10 blur-3xl pointer-events-none"
      style="background: radial-gradient(ellipse, var(--color-accent), transparent 70%);"
      aria-hidden="true">
    </div>

    <div class="relative max-w-7xl mx-auto px-8 pt-28 pb-24">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 border border-[var(--color-border)] rounded-full px-3 py-1 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green)]"></span>
          <span class="font-mono text-xs text-[var(--color-muted)]">v0.1.1 · MIT · Go binary, zero setup</span>
        </div>

        <h1 class="text-5xl sm:text-6xl font-semibold leading-tight tracking-tight text-[var(--color-text)] mb-6">
          Project context,<br />
          <span class="text-[var(--color-accent)]">machine-readable.</span>
        </h1>

        <p class="text-body text-lg mb-10 max-w-xl">
          Every codebase has context that lives in engineers' heads: why Postgres instead of MySQL,
          what you must never log, which layer owns what.
          <code class="code-inline">CONTEXT.yaml</code> makes it explicit.
          <code class="code-inline">ktext</code> generates, validates, and scores it.
        </p>

        <div class="flex items-stretch bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden max-w-2xl">
          <div class="flex items-center gap-3 flex-1 min-w-0 px-4 py-3 overflow-x-auto">
            <span class="font-mono text-sm text-[var(--color-muted)] select-none shrink-0">$</span>
            <code id="install-cmd" class="font-mono text-sm text-[var(--color-text)] select-all whitespace-nowrap">{installCmd}</code>
          </div>
          <button
            id="copy-install"
            class="font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] hover:bg-[var(--color-surface-2)] transition-colors shrink-0 cursor-pointer px-4 py-3 border-l border-[var(--color-border)]"
            aria-label="Copy install command"
          >copy</button>
        </div>

        <div class="flex items-center gap-4 mt-6">
          <a href="/docs" class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-[var(--color-bg)] font-medium text-sm px-5 py-2.5 rounded-lg transition-colors">
            Get started
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 0 1 0-1.06z"/></svg>
          </a>
          <a href="https://github.com/arithmetike/ktext" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">
            View on GitHub →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="section">
    <div class="section-inner grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="label-eyebrow">The problem</p>
        <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-4 leading-snug">
          Context lives in engineers' heads.<br />Agents and new hires don't have that.
        </h2>
        <p class="text-body mb-4">
          When a new engineer joins, or an AI agent opens a PR, they work without the institutional knowledge your team takes for granted. They make reasonable guesses. Those guesses are often wrong.
        </p>
        <p class="text-body">
          <code class="code-inline">CONTEXT.yaml</code> captures what matters in a structured file both humans and tools can read: constraints, decisions, risks, and conventions.
        </p>
      </div>
      <div class="space-y-3">
        {[
          { label: 'constraints', text: 'Never log raw card data or PII in any request handler', tag: 'PCI compliance' },
          { label: 'decisions', text: 'Use PostgreSQL for all persistent state', tag: 'accepted' },
          { label: 'risks', text: 'Migration rollback untested beyond 2 versions', tag: 'high' },
        ].map(item => (
          <div class="card px-4 py-3">
            <div class="flex items-center justify-between mb-1">
              <span class="font-mono text-xs text-[var(--color-accent)]">{item.label}</span>
              <span class="font-mono text-xs text-[var(--color-muted)] bg-[var(--color-surface-2)] border border-[var(--color-border)] px-2 py-0.5 rounded-full">{item.tag}</span>
            </div>
            <p class="text-sm text-[var(--color-muted)]">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="section-inner">
      <p class="label-eyebrow">How it works</p>
      <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-12">Three commands.</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {steps.map(step => (
          <div class="card p-6">
            <p class="font-mono text-xs text-[var(--color-muted)] mb-3">{step.label}</p>
            <div class="font-mono text-sm text-[var(--color-cyan)] bg-[var(--color-surface-2)] border border-[var(--color-border)] rounded px-3 py-2 mb-4">
              $ {step.cmd}
            </div>
            <h3 class="text-[var(--color-text)] font-medium mb-2">{step.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTEXT.yaml as a standard -->
  <section class="section">
    <div class="section-inner grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <p class="label-eyebrow">The standard</p>
        <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-4 leading-snug">
          One file.<br />Everything an agent needs.
        </h2>
        <p class="text-body mb-4">
          An agent reading your codebase cold will spend tokens on config files, grep for conventions, and still miss things. Give it <code class="code-inline">CONTEXT.yaml</code> and it starts with the full picture.
        </p>
        <p class="text-body mb-8">
          No database, no server, no account. It lives at the root of your repo, versioned with your code, readable by anything that can parse YAML.
        </p>

        <div class="grid grid-cols-3 gap-4 mb-8">
          {[
            { stat: '~50', unit: 'lines', label: 'replaces hours of codebase exploration' },
            { stat: '<2k', unit: 'tokens', label: 'for the full file as XML' },
            { stat: '0', unit: 'deps', label: 'plain YAML, no tooling required' },
          ].map(item => (
            <div class="card p-4 text-center">
              <div class="font-mono text-xl font-semibold text-[var(--color-accent)]">{item.stat}</div>
              <div class="font-mono text-xs text-[var(--color-muted)] mb-1">{item.unit}</div>
              <div class="text-xs text-[var(--color-muted)] leading-tight">{item.label}</div>
            </div>
          ))}
        </div>

        <a href="/docs/schema" class="link-accent inline-flex items-center gap-1.5 text-sm">
          Full schema reference →
        </a>
      </div>

      <div>
        <div class="rounded-lg overflow-hidden border border-[var(--color-border)]">
          <div class="block-header">
            <span>CONTEXT.yaml</span>
          </div>
          <pre class="p-4 text-xs leading-relaxed bg-[var(--color-surface)]"><code class="font-mono text-[var(--color-muted)]">{yamlExample}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Scoring -->
  <section class="section">
    <div class="section-inner grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <p class="label-eyebrow">Quality scoring</p>
        <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-4 leading-snug">
          Not just presence.<br />Quality matters.
        </h2>
        <p class="text-body mb-4">
          "Be careful with auth" is noise. "Never store raw credentials in application logs, use structured redaction middleware" is signal. The scorer knows the difference and tells you what to fix.
        </p>
        <p class="text-body mb-8">
          Each section is scored for presence, completeness, and language quality across eight weighted categories.
        </p>
        <a href="/docs/scoring" class="link-accent inline-flex items-center gap-1.5 text-sm">
          How scoring works →
        </a>
      </div>
      <div>
        <ScoreCard />
      </div>
    </div>
  </section>

  <!-- CI callout -->
  <section class="section">
    <div class="section-inner">
      <div class="max-w-2xl">
        <p class="label-eyebrow">CI integration</p>
        <h2 class="text-2xl font-semibold text-[var(--color-text)] mb-4">Keep quality from slipping.</h2>
        <p class="text-body mb-6">
          <code class="code-inline">ktext validate</code> exits 1 below your threshold. One step in CI and context rot becomes a failing check.
        </p>
      </div>
      <div class="rounded-lg overflow-hidden border border-[var(--color-border)] max-w-2xl">
        <div class="block-header">
          <span>.github/workflows/context.yml</span>
        </div>
        <pre class="overflow-x-auto p-4 text-sm leading-relaxed bg-[var(--color-surface)]"><code class="font-mono text-[var(--color-muted)]"><span class="text-[var(--color-accent)]">-</span> <span class="text-[var(--color-text)]">name</span>: Validate CONTEXT.yaml
  <span class="text-[var(--color-text)]">run</span>: |
    go install github.com/arithmetike/ktext/cmd/ktext@latest
    ktext validate -threshold 80</code></pre>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="section-inner text-center">
      <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-4">Start in seconds.</h2>
      <p class="text-body mb-8 max-w-md mx-auto">Install, run <code class="code-inline">ktext init</code>, and you'll have a scored CONTEXT.yaml before your next coffee.</p>
      <div class="flex items-center justify-center gap-4">
        <a href="/docs" class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-[var(--color-bg)] font-medium text-sm px-6 py-3 rounded-lg transition-colors">
          Read the docs
        </a>
        <a href="/docs/schema" class="link-accent text-sm">
          Schema reference →
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  document.getElementById('copy-install')?.addEventListener('click', async () => {
    const btn = document.getElementById('copy-install')!;
    const text = document.getElementById('install-cmd')?.innerText ?? '';
    await navigator.clipboard.writeText(text.trim());
    btn.textContent = 'copied!';
    setTimeout(() => { btn.textContent = 'copy'; }, 2000);
  });
</script>
